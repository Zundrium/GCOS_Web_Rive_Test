{
  "name": "@gcos/web-rive-test",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "gcos-generate",
    "install:all": "npm install && npm --prefix apps/operator install && npm --prefix apps/interactive install",
