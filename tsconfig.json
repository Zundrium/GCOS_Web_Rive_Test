{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@gcos/io": [".gcos/io/typescript/index.ts"],
      "@gcos/io/types": [".gcos/io/typescript/types.ts"],
      "@gcos/io/logging": [".gcos/io/typescript/logging/index.ts"],
      "@gcos/io/logging/sentry-config": [".gcos/io/typescript/logging/sentry-config.ts"]
    }
  },
  "include": ["apps/operator/src", "apps/interactive/src", "apps/shared/src", ".gcos/io/typescript"]
}
